# 백엔드 Edge Function 베이스 URL.
#  - 로컬: supabase functions serve api --no-verify-jwt → 아래 기본값
#  - 배포: https://<project-ref>.supabase.co/functions/v1/api
VITE_API_BASE_URL=http://localhost:54321/functions/v1/api

# Supabase anon key. 게이트웨이 apikey 헤더용(로컬 --no-verify-jwt 면 비워둬도 됨).
VITE_SUPABASE_ANON_KEY=

# API 타임아웃(ms). 미지정 시 10000.
VITE_API_TIMEOUT_MS=10000

# 토스 appLogin 실패 시 /auth/dev-login 으로 우회할지(개발 편의). 운영 빌드는 false 권장.
VITE_ENABLE_DEV_LOGIN=true

# 초대 링크 기반 URL. Toss WebView에서는 window.location.origin이 CloudFront URL이라
# 그대로 공유하면 MissingKey 에러 발생. 미니앱의 공개 URL을 설정.
# 예: https://toss.im/mini-apps/nyamnyam-together  (실제 URL은 앱인토스 콘솔 확인)
# 미설정 시 window.location.origin 폴백 (로컬 개발에선 비워도 됨).
VITE_INVITE_BASE_URL=
