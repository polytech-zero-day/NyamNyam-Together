# 환경변수 템플릿. 이 파일을 .env로 복사한 뒤 실제 값을 채운다.
#   cp .env.example .env
# ⚠️ 실제 시크릿은 .env(gitignore됨)에만. 이 파일엔 절대 실제 값을 넣지 말 것.

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 서버 전용, 절대 노출 금지
SUPABASE_ANON_KEY=your-anon-key

# 카카오 로컬 API (서버 전용, 절대 프론트 노출 금지)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Claude API (웹서치 보완 + 추천 이유 생성, seed 스크립트에도 필요)
ANTHROPIC_API_KEY=your-anthropic-api-key

# 토스 로그인 mTLS 인증서 경로 (콘솔에서 발급)
TOSS_MTLS_CERT_PATH=./certs/cert.pem
TOSS_MTLS_KEY_PATH=./certs/key.pem

# JWT (랜덤 충분히 긴 문자열)
JWT_SECRET=change-this-to-a-long-random-secret

PORT=3000
