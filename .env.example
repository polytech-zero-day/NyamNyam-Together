# 환경변수 템플릿. 이 파일을 .env로 복사한 뒤 실제 값을 채운다.
#   cp .env.example .env
# ⚠️ 실제 시크릿은 .env(gitignore됨)에만. 이 파일엔 절대 실제 값을 넣지 말 것.

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 서버 전용, 절대 노출 금지
SUPABASE_ANON_KEY=your-anon-key                   # (선택) 클라이언트 직접 접근용. 현재 서버는 미사용

# 구글 Places API (New) — 서버 전용, 절대 프론트 노출 금지 (google-places-api.md)
# 키에 서버 IP/HTTP 리퍼러 제한 적용 권장.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# 토스 로그인 mTLS 인증서 경로 (콘솔에서 발급)
TOSS_MTLS_CERT_PATH=./certs/cert.pem
TOSS_MTLS_KEY_PATH=./certs/key.pem

# JWT (랜덤 충분히 긴 문자열)
JWT_SECRET=change-this-to-a-long-random-secret

# CORS 허용 오리진 (쉼표 구분). 비우면 전체 허용(개발용). 운영은 토스 도메인으로 제한.
#   예: CORS_ORIGIN=https://service.tossmini.com
CORS_ORIGIN=

PORT=3000
